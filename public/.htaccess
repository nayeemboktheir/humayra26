<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^assets/index-(BQHE-_WD|DaxjUk2z)\.js$ /assets/tradeon-app-20260717-v8.js?cache_bust=20260717-force-hostinger-v8 [R=302,L]
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Entry documents must always be fresh so they can reference the newest hashed assets.
  <FilesMatch "^index\.html$|^registerSW\.js$|^manifest\.webmanifest$|^favicon(-20260701)?\.(ico|png)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Long-cache versioned/hashed build assets (filenames change on each release).
  <FilesMatch "^tradeon-(app|chunk|asset|style|live)-.*\.(js|css|png|jpg|jpeg|gif|svg|webp|woff2?|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset Pragma
    Header unset Expires
  </FilesMatch>

  <FilesMatch "^sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
    Header set Clear-Site-Data '"cache", "storage", "executionContexts"'
  </FilesMatch>

  <FilesMatch "^index\.html$">
    Header set Clear-Site-Data '"cache"'
  </FilesMatch>
</IfModule>

